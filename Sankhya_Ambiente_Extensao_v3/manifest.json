{
  "manifest_version": 3,
  "name": "Sankhya Environment Identifier",
  "version": "3.0.0",
  "description": "Identifica Produção e Teste automaticamente.",

  "permissions": [
    "tabs"
  ],

  "host_permissions": [
    "http://haiala.snk.ativy.com:40172/*",
    "https://haiala.snk.ativy.com:40172/*",
    "http://haiala.snk.ativy.com:50172/*",
    "https://haiala.snk.ativy.com:50172/*",

    "https://snkbrp01672.ativy.com/*",
    "https://snkbrt01672.ativy.com/*"
  ],

  "action": {
    "default_title": "Sankhya Ambiente",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "http://haiala.snk.ativy.com:40172/*",
        "https://haiala.snk.ativy.com:40172/*",
        "http://haiala.snk.ativy.com:50172/*",
        "https://haiala.snk.ativy.com:50172/*",

        "https://snkbrp01672.ativy.com/*",
        "https://snkbrt01672.ativy.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ]
    }
  ]
}